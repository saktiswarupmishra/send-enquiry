generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Enquiry {
  id          Int      @id @default(autoincrement())
  destination String?
  tripType    String?
  vehicleType String?
  vehicleName String?
  pickupPoint String?
  stops       String?  @db.Text
  fullName    String?
  phone       String?
  email       String?
  notes       String?  @db.Text
  createdAt   DateTime @default(now())
}
