generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Enquiry {
  id           Int      @id @default(autoincrement())
  serviceType  String?
  destination  String?
  tripType     String?
  vehicleType  String?
  vehicleName  String?
  pickupPoint  String?
  dropPoint    String?
  stops        String?  @db.Text
  travelDate   String?
  travelTime   String?
  passengers   Int?
  flightNumber String?
  airportName  String?
  fullName     String?
  phone        String?
  email        String?
  notes        String?  @db.Text
  createdAt    DateTime @default(now())
}
